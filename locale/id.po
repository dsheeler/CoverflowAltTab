msgstr "Sakelar Properti"

#: src/prefs.js:137
msgid "Flip Stack"
msgstr "Balikkan Tumpukkan"

#: src/prefs.js:143
msgid "Carousel"
msgstr "Korsel"

#: src/prefs.js:149
msgid "Looping Method"
msgstr "Metode Perulangan"

#: src/prefs.js:149
msgid "How to cycle through windows."
msgstr "Cara beralih antar jendela."

#: src/prefs.js:153
msgid "Coverflow"
msgstr "Penutup"

#: src/prefs.js:159
msgid "Timeline"
msgstr "Garis waktu"

#: src/prefs.js:164
msgid "Style"
msgstr "Gaya"

#: src/prefs.js:164
msgid "Pick the type of switcher."
msgstr "Pilih jenis dari sakelar."

#: src/prefs.js:165
msgid "Vertical Offset"
msgstr "Offset Vertikal"

#: src/prefs.js:165
msgid "Positive value moves everything down, negative up."
msgstr ""
"Nilai positif menurunkan seluruhnya, sedangkan nilai negatif menaikkan "
"seluruhnya."

#: src/prefs.js:169
msgid "Bottom"
msgstr "Bawah"

#: src/prefs.js:175
msgid "Top"
msgstr "Atas"

#: src/prefs.js:180
msgid "Window Title Position"
msgstr "Posisi Judul Jendela"

#: src/prefs.js:180
msgid "Place window title above or below the switcher."
msgstr "Letakkan judul jendela di atas atau di bawah sakelar."

#: src/prefs.js:181
msgid "Enforce Primary Monitor"
msgstr "Terapkan Pengawas Utama"

#: src/prefs.js:181
msgid ""
"Always show on the primary monitor, otherwise, show on the active monitor."
msgstr ""
"Selalu tampilkan di monitor utama, jika tidak, tampilkan di monitor yang "
"aktif."

#: src/prefs.js:184
msgid "Hide Panel"
msgstr "Sembunyikan Panel"

#: src/prefs.js:184
msgid "Hide panel when switching windows."
msgstr "Sembunyikan panel ketika beralih jendela."

#: src/prefs.js:185
msgid "Invert Swipes"
msgstr "Balikkan Geseran"

#: src/prefs.js:185
msgid "Invert system scroll direction setting."
msgstr "Balikkan pengaturan arah gulir sistem."

#: src/prefs.js:189
msgid "Background"
msgstr "Latar belakang"

#: src/prefs.js:191
msgid "Dim-factor"
msgstr "Faktor dimensi"

#: src/prefs.js:191
msgid "Bigger means darker."
msgstr "Lebih besar berarti lebih gelap."

#: src/prefs.js:195
msgid "Animation"
msgstr "Animasi"

#: src/prefs.js:200 src/prefs.js:226 src/prefs.js:286 src/prefs.js:299
msgid "Properties"
msgstr "Properti"

#: src/prefs.js:203
msgid "Easing Function"
msgstr "Fungsi easing"

#: src/prefs.js:203
msgid "Determine how windows move."
msgstr "Menentukan bagaimana jendela bergerak."

#: src/prefs.js:204
msgid "Duration [s]"
msgstr "Durasi [s]"

#: src/prefs.js:205
msgid "Randomize Durations"
msgstr "Acak durasi"

#: src/prefs.js:205
msgid ""
"Each animation duration assigned randomly between 0 and configured duration."
msgstr ""
"Setiap durasi animasi ditetapkan secara acak antara 0 dan durasi yang "
"dikonfigurasi."

#: src/prefs.js:208
msgid "Included"
msgstr "Termasuk"

#: src/prefs.js:211
msgid "Current workspace only"
msgstr "Ruang kerja saat ini"

#: src/prefs.js:213
msgid "All workspaces"
msgstr "Semua ruang kerja"

#: src/prefs.js:215
msgid "All workspaces, current first"
msgstr "Semua ruang kerja, yang saat ini terlebih dahulu"

#: src/prefs.js:217
msgid "Workspaces"
msgstr "Ruang kerja"

#: src/prefs.js:217
msgid "Switch between windows on current or on all workspaces."
msgstr "Beralih antarjendela di ruang kerja saat ini atau di semua ruang kerja."

#: src/prefs.js:218
msgid "Current Monitor"
msgstr "Monitor Saat Ini"

#: src/prefs.js:218
msgid "Switch between windows on current monitor."
msgstr "Beralih antarjendela di monitor saat ini."

#: src/prefs.js:221
msgid "Icons"
msgstr "Ikon"

#: src/prefs.js:230
msgid "Overlay Icon Size"
msgstr "Ukuran ikon overlay"

#: src/prefs.js:230
msgid "Set the overlay icon size in pixels."
msgstr "Atur ukuran ikon overlay dalam piksel."

#: src/prefs.js:231
msgid "Overlay Icon Opacity"
msgstr "Opasitas ikon overlay"

#: src/prefs.js:231
msgid "Set the overlay icon opacity."
msgstr "Atur opasitas ikon overlay."

#: src/prefs.js:235
msgid "Classic"
msgstr "Klasik"

#: src/prefs.js:241
msgid "Overlay"
msgstr "Overlay"

#: src/prefs.js:247
msgid "Attached"
msgstr "Terlampir"

#: src/prefs.js:252
msgid "Application Icon Style"
msgstr "Gaya ikon aplikasi"

#: src/prefs.js:257
msgid "Fade Only"
msgstr "Hanya pudar"

#: src/prefs.js:263
msgid "Scale Only"
msgstr "Hanya skala"

#: src/prefs.js:269
msgid "Fade and Scale"
msgstr "Pudar dan skala"

#: src/prefs.js:274
msgid "Add / Remove Effects"
msgstr "Tambah / Hapus Efek"

#: src/prefs.js:274
msgid "How Icons and Labels ease in and out."
msgstr "Bagaimana ikon dan label melakukan easing saat masuk dan keluar."

#: src/prefs.js:278
msgid "Icon Shadow"
msgstr "Bayangan Ikon"

#: src/prefs.js:282
msgid "Windows"
msgstr "Jendela"

#: src/prefs.js:290
msgid "Window Preview Size to Monitor Size Ratio"
msgstr "Rasio ukuran pratinjau jendela terhadap ukuran monitor"

#: src/prefs.js:290
msgid "Maximum ratio of window preview size to monitor size."
msgstr "Rasio maksimum ukuran pratinjau jendela terhadap ukuran monitor."

#: src/prefs.js:291
msgid "Off-center Size Factor"
msgstr "Faktor ukuran di luar pusat"

#: src/prefs.js:291
msgid "Factor by which to successively shrink previews off to the side."
msgstr ""
"Faktor untuk memperkecil pratinjau yang berada di samping secara bertahap."

#: src/prefs.js:292
msgid "Coverflow Window Angle"
msgstr "Sudut jendela coverflow"

#: src/prefs.js:292
msgid "Angle of off-center windows in coverflow mode."
msgstr "Sudut jendela yang berada di luar pusat dalam mode coverflow."

#: src/prefs.js:293
msgid "Coverflow Window Offset Width"
msgstr "Lebar offset jendela coverflow"

#: src/prefs.js:293
msgid "How far windows are off to the side in coverflow mode."
msgstr "Seberapa jauh jendela bergeser ke samping dalam mode coverflow."

#: src/prefs.js:295
msgid "AppSwitcher"
msgstr "AppSwitcher"

#: src/prefs.js:302
msgid "Make the Application Switcher Show Only First Preview"
msgstr "Buat Application Switcher hanya menampilkan pratinjau pertama"

#: src/prefs.js:302
msgid "Don't group windows of the same application in a subswitcher."
msgstr "Jangan kelompokkan jendela dari aplikasi yang sama dalam subswitcher."

#: src/prefs.js:303
msgid "Desaturate"
msgstr "Desaturasi"

#: src/prefs.js:303
msgid "Larger means more desaturation."
msgstr "Semakin besar nilainya, semakin tinggi desaturasinya."

#: src/prefs.js:306
msgid "Tint"
msgstr "Tint"

#: src/prefs.js:318 src/prefs.js:448
msgid "Color"
msgstr "Warna"

#: src/prefs.js:339 src/prefs.js:472
msgid "Set to Theme Color"
msgstr "Ubah ke Warna Tema"

#: src/prefs.js:397
msgid "Blend"
msgstr "Campur"

#: src/prefs.js:397
msgid "How much to blend the tint color; bigger means more tint color."
msgstr ""
"Seberapa banyak warna tint dicampurkan; semakin besar nilainya, semakin kuat "
"warna tint."

#: src/prefs.js:398
msgid "Glitch"
msgstr "Glitch"

#: src/prefs.js:401
msgid "Keybindings"
msgstr "Ikatan tombol"

#: src/prefs.js:406
msgid "System Actions Keybindings"
msgstr "Ikatan tombol tindakan sistem"

#: src/prefs.js:407
msgid ""
"In case of conflicts with other window switchers, can unbind from system "
"actions."
msgstr ""
"Jika terjadi konflik dengan window switcher lain, ikatan dapat dilepas dari "
"tindakan sistem."

#: src/prefs.js:410
msgid "Bind to 'switch-windows'"
msgstr "Ikat ke 'switch-windows'"

#: src/prefs.js:411
msgid "Bind to 'switch-applications'"
msgstr "Ikat ke 'switch-applications'"

#: src/prefs.js:414
msgid "Internal Actions Keybindings"
msgstr "Ikatan tombol tindakan internal"

#: src/prefs.js:415
msgid "Internal actions that will not conflict with other window switchers."
msgstr ""
"Tindakan internal yang tidak akan menimbulkan konflik dengan window switcher "
"lain."

#: src/prefs.js:418
msgid "Coverflow Switch Windows Shortcut"
msgstr "Shortcut Coverflow Switch Windows"

#: src/prefs.js:418
msgid "Activate window switcher."
msgstr "Aktifkan window switcher."

#: src/prefs.js:419
msgid "Coverflow Switch Applications Shortcut"
msgstr "Shortcut Coverflow Switch Applications"

#: src/prefs.js:419
msgid "Activate application switcher."
msgstr "Aktifkan application switcher."

#: src/prefs.js:422
msgid "Advanced Options"
msgstr "Opsi lanjutan"

#: src/prefs.js:426
msgid "None"
msgstr "Tidak ada"

#: src/prefs.js:427
msgid "Move Camera"
msgstr "Gerakan Kamera"

#: src/prefs.js:428
msgid "Adjust Angles"
msgstr "Sesuaikan sudut"

#: src/prefs.js:429
msgid "Perspective Correction"
msgstr "Koreksi perspektif"

#: src/prefs.js:429
msgid "Method to make off-center switcher look centered."
msgstr "Metode untuk membuat switcher yang di luar pusat terlihat terpusat."

#: src/prefs.js:431
msgid "Verbose Logging"
msgstr "Logging verbose"

#: src/prefs.js:431
msgid "Log debug and normal messages."
msgstr "Catat pesan debug dan pesan normal."

#: src/prefs.js:435
msgid "Highlight Window Under Mouse"
msgstr "Sorot jendela di bawah mouse"

#: src/prefs.js:436
msgid ""
"Draw a colored highlight on window under the mouse to know the effects of "
"clicking."
msgstr ""
"Gambar sorotan berwarna pada jendela di bawah mouse agar efek klik dapat "
"diketahui."

#: src/prefs.js:526
msgid "Raise Window Under Mouse"
msgstr "Naikkan jendela di bawah mouse"

#: src/prefs.js:526
msgid "Raise the window under the mouse above all others."
msgstr "Naikkan jendela di bawah mouse ke atas semua jendela lainnya."

#: src/prefs.js:529
msgid "Contribute"
msgstr "Kontribusi"

#: src/prefs.js:565
msgid "Code (create pull requests, report issues, etc.)"
msgstr "Code (buat pull request, laporkan issue, dll.)"

#: src/prefs.js:573
msgid "Donate"
msgstr "Donasi"

#: src/prefs.js:594
msgid "Translate"
msgstr "Terjemahkan"

